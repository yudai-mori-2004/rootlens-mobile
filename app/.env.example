# Sandbox 04 (Collection Flow) — VLM provider keys.
# 注意: EXPO_PUBLIC_* は JS bundle に inline されるため、本番では backend proxy 経由にする。

# default provider = claude (vlmClient.ts の DEFAULT_VLM_PROVIDER)
# https://console.anthropic.com/settings/keys
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Task 08: Privy + Solana + Title Protocol
# ---------------------------------------------------------------------------

# Privy (https://dashboard.privy.io/) で app を作成して取得。
# Login methods: Google OAuth を有効化、Embedded Solana wallet を有効化。
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Solana devnet RPC。Helius / QuickNode 等の専用 endpoint 推奨。
# 未設定時は titleProtocol.ts の default (root-lens 由来 helius devnet) が使われる。
EXPO_PUBLIC_SOLANA_RPC_URL=

# Title Protocol Gateway。client.selectNode() で auto-pick されるため通常未設定で OK。
# 特定 node を強制したい場合のみ "http://<host>:<port>" を入れる。
EXPO_PUBLIC_TP_GATEWAY_URL=

# Demo mode: Privy login をスキップして TP register の owner_wallet をここから読む。
# devnet の Phantom 等で生成した wallet pubkey を入れる。値なしなら TP register は skip。
EXPO_PUBLIC_DEMO_WALLET_ADDRESS=
